# Turso SQLite — get from https://console.turso.tech
# Create a database, then run: turso db tokens create <db-name>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Upstash Redis — get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
